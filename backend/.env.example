NODE_ENV=development
PORT=8080
DATABASE_URL=postgres://postgres:password@localhost:5432/amberkitchen
JWT_SECRET=replace-with-long-secret
CORS_ORIGINS=http://localhost:4200,https://your-ui.azurestaticapps.net
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_PLACES_API_KEY=your-google-places-api-key
OTP_TTL_SECONDS=300
PAYTM_MID=your-paytm-mid
PAYTM_MERCHANT_KEY=your-paytm-merchant-key
PAYTM_WEBSITE=WEBSTAGING
PAYTM_CALLBACK_URL=https://api.example.com/api/payments/paytm/callback
PHONEPE_MERCHANT_ID=your-phonepe-merchant-id
PHONEPE_SALT_KEY=your-phonepe-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_CALLBACK_URL=https://api.example.com/api/payments/phonepe/callback
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_CALLBACK_URL=https://api.example.com/api/payments/razorpay/callback
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
FCM_SERVICE_ACCOUNT_JSON={}
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://your-resource.communication.azure.com/;accesskey=your-access-key
AZURE_SMS_FROM=+15555550123
AZURE_EMAIL_FROM=no-reply@example.com
AZURE_WHATSAPP_FROM=+15555550123
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorage;AccountKey=your-key;EndpointSuffix=core.windows.net
AZURE_STORAGE_ACCOUNT_NAME=yourstorage
AZURE_STORAGE_CONTAINER=amberkitchen-assets
AZURE_COMPUTER_VISION_ENDPOINT=https://your-vision.cognitiveservices.azure.com
AZURE_COMPUTER_VISION_KEY=your-computer-vision-key
AZURE_FACE_ENDPOINT=https://your-face.cognitiveservices.azure.com
AZURE_FACE_KEY=your-face-key
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...
