{
  "expo": {
    "name": "AK Ops",
    "slug": "amberkitchen-mobile",
    "scheme": "amberkitchen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f0f"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amberkitchen.mobile",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AmberKitchen uses your location for restaurant distance, delivery ETA, and live driver tracking.",
        "NSCameraUsageDescription": "AmberKitchen uses camera access for driver selfie verification and onboarding document capture.",
        "NSPhotoLibraryUsageDescription": "AmberKitchen uses photo library access for driver Aadhaar and selfie uploads."
      },
      "config": {
        "googleMapsApiKey": ""
      }
    },
    "android": {
      "package": "com.amberkitchen.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#E23744"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "POST_NOTIFICATIONS"
      ],
      "config": {
        "googleMaps": {
          "apiKey": ""
        }
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-location",
      "expo-notifications"
    ],
    "extra": {
      "apiBaseUrl": "",
      "socketUrl": "",
      "googleMapsApiKey": ""
    }
  }
}
