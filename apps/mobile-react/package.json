{
  "name": "@amberkitchen/mobile-react",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": [
        "babel-jest",
        {
          "presets": [
            "babel-preset-expo"
          ]
        }
      ]
    },
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^expo-constants$": "<rootDir>/__mocks__/expo-constants.js",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.js",
      "^expo-location$": "<rootDir>/__mocks__/expo-location.js",
      "^expo-network$": "<rootDir>/__mocks__/expo-network.js",
      "^expo-notifications$": "<rootDir>/__mocks__/expo-notifications.js",
      "^expo-image-picker$": "<rootDir>/__mocks__/expo-image-picker.js",
      "^expo-file-system$": "<rootDir>/__mocks__/expo-file-system.js",
      "^expo-linking$": "<rootDir>/__mocks__/expo-linking.js",
      "^socket.io-client$": "<rootDir>/__mocks__/socket.io-client.js",
      "^./src/config$": "<rootDir>/__mocks__/config.js"
    },
    "testMatch": [
      "**/__tests__/**/*.test.(ts|tsx|js)"
    ],
    "globals": {
      "__DEV__": true
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "expo": "^54.0.0",
    "expo-auth-session": "~7.0.11",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-network": "~8.0.8",
    "expo-notifications": "^0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "^19.1.0",
    "react-native": "^0.81.5",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.2.6",
    "typescript": "^5.7.2"
  }
}
