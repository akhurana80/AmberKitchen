{
  "name": "@amberkitchen/mobile-react",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "prebuild": "expo prebuild",
    "prebuild:ios": "expo prebuild --platform ios",
    "prebuild:android": "expo prebuild --platform android",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {
      "^.+\\.(ts|tsx|js|jsx)$": ["babel-jest", { "presets": ["babel-preset-expo"] }]
    },
    "moduleNameMapper": {
      "^react-native$": "<rootDir>/__mocks__/react-native.js",
      "^expo-constants$": "<rootDir>/__mocks__/expo-constants.js",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.js",
      "^expo-location$": "<rootDir>/__mocks__/expo-location.js",
      "^expo-network$": "<rootDir>/__mocks__/expo-network.js",
      "^expo-notifications$": "<rootDir>/__mocks__/expo-notifications.js",
      "^expo-image-picker$": "<rootDir>/__mocks__/expo-image-picker.js",
      "^expo-file-system$": "<rootDir>/__mocks__/expo-file-system.js",
      "^expo-linking$": "<rootDir>/__mocks__/expo-linking.js",
      "^socket.io-client$": "<rootDir>/__mocks__/socket.io-client.js",
      "^./src/config$": "<rootDir>/__mocks__/config.js"
    },
    "testMatch": ["**/__tests__/**/*.test.(ts|tsx|js)"],
    "globals": {
      "__DEV__": true
    }
  },
  "dependencies": {
    "@expo/vector-icons": "~14.0.4",
    "expo": "^52.0.0",
    "expo-auth-session": "~6.0.3",
    "expo-constants": "~17.0.8",
    "expo-device": "~7.0.3",
    "expo-file-system": "~18.0.12",
    "expo-image-picker": "~16.0.6",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-network": "~7.0.5",
    "expo-notifications": "~0.29.14",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "^14.0.2",
    "react": "^18.3.1",
    "react-native": "^0.76.5",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.17",
    "react-test-renderer": "^19.2.6",
    "typescript": "^5.7.2"
  }
}
